# .gitattributes — Normalize line endings across platforms
# Ensures all text files use LF in the repo (fixes Windows CRLF warnings)

# Auto-detect text files and normalize
* text=auto

# Force LF for all source/config files
*.java      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.properties text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf
Jenkinsfile text eol=lf
.gitignore  text eol=lf
.env*       text eol=lf
nginx.conf  text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.jar   binary
*.class binary
*.zip   binary
